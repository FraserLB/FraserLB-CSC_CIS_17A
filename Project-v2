}

bool load(char name[], int &balance) {
    ifstream file("save.data", ios::binary);
    if(!file) {
        cout << endl;
        cout << "No save file found!" << endl;
        cout << endl;
        return false;
    }
    file.read(reinterpret_cast<char*>(name), 20);
    file.read(reinterpret_cast<char*>(&balance), sizeof(int));
    file.close();
    cout << "Game loaded." << endl;
    cout << "Welcome back " << name << "!" << endl;
    cout << "Balance: $" << balance << endl;
    return true;
}

void rules() {
    cout << "-----------------------------------------BLACKJACK-----------------------------------------" << endl;
    cout << endl;
    cout << "Rules:" << endl;
    cout << "Every turn the player will recieve two face up cards while the dealer ";  
    cout << "recieves one card up and one card down." << endl;
    cout << "Number cards are counted at their face value, face cards as 10, ";
    cout << "and Aces as 1 or 11." << endl;
    cout << "Each turn, the player has the option to hit or stand." << endl;
    cout << "The player may draw as many times as they like, so long as their "; 
    cout << "hands value is not greater than 21." << endl;
    cout << "If the player hits, they will recieve another card. If they stand, ";
    cout << "the dealer reveals their other card." << endl;
    cout << "The dealer must always draw till his hand is worth 17 or more, ";
    cout << "regardless of the player's hand's value." << endl;
    cout << "If after drawing the dealers hand is still worth less than the players, ";
    cout << "or greater than 21, the player wins." << endl;
    cout << "If the players hand is worth less than the dealers, and the dealer ";
    cout << "is not required to hit, the dealer wins." << endl;
    cout << "A BlackJack, a starting hand of 21, results in an automatic win for the player ";
    cout << "and pays 1.5 times his bet." << endl;
    cout << "A tie results in a push. the players bet is returned." << endl;
    cout << "You may save and quit during your turn by selecting 'q'." << endl;
    cout << endl;
    cout << "-------------------------------------------------------------------------------------------" << endl;
}

void saveRec(char name[], int balance) {
    fstream file("scores.data", ios::binary | ios::in | ios::out | ios::app);
    //Create file
    if(!file) {
        file.open("scored.data", ios::binary | ios::out);
    }
    Record rec;
    strcpy(rec.name, name);
    rec.balance = balance;
    file.seekp(0, ios::end);
    file.write(reinterpret_cast<char*>(&rec), sizeof(Record));
    file.close();
}

void viewRec() {
    ifstream file("scores.data", ios::binary);
    if(!file) {
        cout << "No Records found!" << endl;
        return;
    }
    Record rec;
    int spot = 0;
    cout << "High Scores: " << endl;
    while(file.read(reinterpret_cast<char*>(&rec), sizeof(Record))) {
        cout << spot + 1 << ". " << rec.name << " - $" << rec.balance << endl;
        spot++;
    }
    file.close();
}
