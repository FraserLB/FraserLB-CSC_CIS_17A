using namespace std;

//User Libraries

//Global Constants only

//Conversions/Math/Physics

//Structures
struct Card {
    char names[20];        //Character array for card name
    int value;          //Card value
};

struct Deck {
    Card cards[52];     //Array for storing card objects
    int top;            //Index for card count, starts 0, increments each time card is dealt
};

struct Hand {
    Card hand[10];      //Array for storinf card objects in hand
    int nCards;         //Number of cards in hand
    int totVal;         //Total value of hand.
    int ace;            //Counter for detecting aces in a hand.
};

struct Record {
    char name[20];      //Character array for storing name
    int balance;        //For storing balance
};

//Enumerations
enum gmState {PLAYING, GAMEOVER, SAVED, RNDOVER};

//Function Prototypes
void initDeck(Deck *);
void shuffle(Deck *);
void initHand(Hand *);
void deal(Deck *, Hand *);
void prntHnd(Hand *);
void play(char [], int &);
void rules();
void save(char [], int);
void saveRec(char [], int);
void viewRec();
bool load(char [], int &);

//Execution Begins here
int main(int argc, char** argv) {
    char name[20];          //Player name
    int balance = 2500;     //Starting balance for player in Dollars ($)
    int choice;             //Menu choice

    do {
        cout << "Black-Jack!" << endl;
        cout << "1. Start Game" << endl;
        cout << "2. Load Game" << endl;
        cout << "3. Rules" << endl;
        cout << "4. High Scores" << endl;
        cout << "5. Quit" << endl;
        cin >> choice;
        switch(choice) {
            case 1: {
                //Player name input
                cout << "Enter your name: ";
                cin.ignore();
                cin.getline(name, 20);
                cout << endl;
                //Welcome message
                cout << "Welcome, " << name <<"! Your starting balance is $" << balance << endl;
                cout << "Game start!" << endl; 
                play(name, balance); 
                break;
            }
            case 2: {
                bool loaded = load(name, balance);
                if(loaded) {
                    play(name, balance);
                }
                break;
            }
            case 3: {
                rules();
                break;
            } 
            case 4: {
                viewRec();
                break;
            }
        }
    } while(choice != 5);
    return 0;
}

void initDeck (Deck *deck) {
    string suits[] = {"Hearts", "Diamonds", "Spades", "Clubs"};
    string ranks[] = {"2", "3", "4", "5", "6", "7", "8", "9", "10",
                      "Jack", "Queen", "King", "Ace"};
    int values[] = {2,3,4,5,6,7,8,9,10,10,10,10,11};

    int idx = 0;    //Index for count
    for(int s = 0; s < 4; s++) {
        for(int r = 0; r < 13; r++) {
            string flName = ranks[r] + " of " + suits[s];
            strcpy(deck->cards[idx].names, flName.c_str());
            deck->cards[idx].value = values[r];
            idx++;
        }
    }
}

void shuffle(Deck *deck) {
    srand(time(0));
    for(int i = 51; i > 0; i--){
        int j = rand() % (i + 1);
        Card temp = deck->cards[i];
        deck->cards[i] = deck->cards[j];
        deck->cards[j] = temp;
    }
    deck->top = 0;
}

void initHand(Hand *hand) {
    hand->nCards = 0;
    hand->totVal = 0;
    hand->ace = 0;
}

void deal(Deck *deck, Hand *hand) {
    //Deal card
    hand->hand[hand->nCards] = deck->cards[deck->top];
    //Adjust value of hand
    hand->totVal += deck->cards[deck->top].value;
    //Check for an ace
    if(hand->hand[hand->nCards].value == 11) {
        hand->ace++;
    }
    //Increment
    deck->top++;
    hand->nCards++;
    //Adjust for aces
    if(hand->totVal > 21 && hand->ace > 0) {
        hand->totVal -= 10;
        hand->ace--;
    }
}

void prntHnd(Hand *hand) {
    for(int i = 0; i < hand->nCards; i++) {
        cout << hand->hand[i].names << ", " << hand->hand[i].value << endl;
    }
    cout << hand->totVal << endl;
}

void play(char name[], int &balance) {
    //Initialization
    Deck *deck = new Deck;
    Hand *player = new Hand;
    Hand *dealer = new Hand;
    initDeck(deck);
    shuffle(deck);
    //Declare variables
    char choice = ' ';                    //Choice variabble for hit/stand loop
    int bet;                               //Players bet, $10-$500
    gmState state;
    //Game loop
    do {
        state = PLAYING;
        //re-shuffle condition
        if(deck->top > 45) {
            cout << "Reshuffling Deck" << endl;
            initDeck(deck);
            shuffle(deck);
        }
        //Initiate Hand
        initHand(player);
        initHand(dealer);
        //Place bet
        do {
            cout << "Place your bet ($10-$500): $";
            cin >> bet;
            if(bet == 0) {
                save(name, balance);
                delete deck;
                delete player;
                delete dealer;
                return;     //exit
            }
            if(bet > balance) {
                cout <<"You cannot bet more than your balance of $" << balance << "!" << endl;
            }
        } while(bet < 10 || bet > 500 || bet > balance);
        //Deal
        deal(deck, player);
        deal(deck, dealer);
        deal(deck, player);
        deal(deck, dealer);
        //Print dealer hand
        cout << endl;
        cout << "-----------------------------------------BLACKJACK-----------------------------------------" << endl;
        cout << endl;
        cout << "Dealer shows: " << dealer->hand[0].names << " (" << 
        dealer->hand[0].value << ") " << endl;
        cout << "Dealers second card is face down" << endl;
        //Print player hand
        cout << endl;
        cout << "Your hand: " << endl;
        prntHnd(player);
        cout << endl;
        //Check for blackjack
        if(player->totVal == 21) {
                cout << "Black Jack!" << endl;
                cout << "You win $" << bet*1.5 << endl;
                balance += (bet)*(1.5);
                cout << "New balance: $" << balance << endl;
                state = RNDOVER;
            }
        if(state == PLAYING) {
            //Hit-Stand loop
        do {
            cout << "Hit (h), Stand (s), or Save and Quit (q): ";
            cin >> choice;
            if(choice == 'h') {
                deal(deck, player);
                cout << "Your hand:" << endl;
                prntHnd(player);
            }
        } while(choice != 's' && choice != 'q' && player->totVal <= 21);
        }
        //Save and Quit
        if(choice == 'q') {
            save(name, balance);
            saveRec(name, balance);
            state = SAVED;
        }
        //Check for bust
        if(player->totVal > 21) {
            cout << "Bust! You lose $" << bet << endl;
            cout << endl;
            balance -= bet;
            state = RNDOVER;
        }
        //Dealer logic 
        if(state == PLAYING) {
            //Print Dealer hand
            cout << endl;
            cout << "Dealers hand: " << endl;
            prntHnd(dealer);
            cout << endl;
            //Dealer draws till 17+
            while(dealer->totVal < 17) {
                cout << "Dealer hits" << endl;
                cout << endl;
                deal(deck, dealer);
                prntHnd(dealer);
                cout << endl;
            }
            //Check for bust out
            if(dealer->totVal > 21) {
            cout << "Bust! You win $" << bet << endl;
            balance += bet;
            state = RNDOVER;
            } else if (player->totVal > dealer->totVal) {
                cout << "You win $" << bet << endl;
                balance += bet;
            } else if (player->totVal < dealer->totVal) {
                cout << "Dealer wins! You lose $" << bet << endl;
                balance -= bet;
            } else {
                cout << "Push! Bet returned." << endl;
            }
        }
        cout << endl;
        cout << "Current balance: $" << balance << endl;
        if(balance < 10) {
            state = GAMEOVER;
        }
    } while(state == PLAYING || state == RNDOVER);
    if(state == GAMEOVER) {
        cout << endl;
        cout << "Out of money!" << endl;
        cout << "Game over!" << endl;
        cout << endl;
    }
    delete deck;
    delete player;
    delete dealer;
}

void save(char name[], int balance) {
    ofstream file("save.data", ios::binary);
    file.write(reinterpret_cast<char*>(name), 20);
    file.write(reinterpret_cast<char*>(&balance), sizeof(int));
    file.close();
